#include <iostream>
using namespace std;
void printTable(int number) 
{
    for (int i = 1; i <= 10; ++i) {
        cout << number << " x " << i << " = " << number * i << endl;
    }
}
int main() 
{
    int num;
    cout << "Enter a number to print its multiplication table: ";
    cin >> num;
    printTable(num);
    return 0;
}
